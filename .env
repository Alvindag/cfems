# CFEMS — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then edit .env with your actual database password.
# NEVER commit .env to Git.

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cfems
DB_USER=postgres
DB_PASSWORD=122333

# Flask
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=False
FLASK_PORT=5000
